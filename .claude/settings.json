{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix {{file_path}}",
            "description": "TypeScript/TSXファイル編集時に自動lint"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix {{file_path}}",
            "description": "TypeScript/TSXファイル作成時に自動lint"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status",
            "description": "セッション開始時にgit statusを表示"
          }
        ]
      }
    ]
  }
}
