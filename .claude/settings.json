{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "case '{{file_path}}' in *.ts|*.tsx|*.js|*.jsx) npx eslint --fix '{{file_path}}' ;; esac",
            "description": "TypeScript/TSXファイル編集時に自動lint"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "case '{{file_path}}' in *.ts|*.tsx|*.js|*.jsx) npx eslint --fix '{{file_path}}' ;; esac",
            "description": "TypeScript/TSXファイル作成時に自動lint"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status",
            "description": "セッション開始時にgit statusを表示"
          }
        ]
      }
    ]
  }
}
